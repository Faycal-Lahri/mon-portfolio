{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(css|js|images|storage)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "DB_CONNECTION": "pgsql",
    "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
    "SESSION_DRIVER": "cookie",
    "LOG_CHANNEL": "stderr",
    "CACHE_DRIVER": "array"
  }
}
