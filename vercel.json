{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "installCommand": "composer install --no-dev --optimize-autoloader && npm install",
  "buildCommand": "php artisan package:discover --ansi && php artisan config:cache && php artisan route:cache && npm run build",
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "public/build/$1"
    },
    {
      "src": "/(assets|css|js|images|favicon.ico|robots.txt)(.*)",
      "dest": "public/$1$2"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "cookie",
    "CACHE_DRIVER": "array",
    "TRUSTED_PROXIES": "*"
  }
}
